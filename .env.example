# Local development defaults. On Render, these are set for you by render.yaml.
PORT=4000

# REQUIRED in production. Use a long random string. Render generates this automatically.
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Where the SQLite file lives.
#   Local:      ./db/marathon.sqlite
#   Render disk: /data/marathon.sqlite   (set via render.yaml)
DB_PATH=./db/marathon.sqlite

# Single-service deploy serves the site and API from the same origin, so CORS is
# effectively unused. Left here only for split-origin local setups.
CORS_ORIGIN=*
